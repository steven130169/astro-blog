---
import { SITE_TITLE } from '../consts';
---

<nav class="fixed w-full z-50 bg-white/80 backdrop-blur-md border-b border-border-light shadow-sm py-4 transition-all duration-300">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex justify-between items-center">
			<a href="/#home" class="flex-shrink-0 flex items-center gap-2 cursor-pointer no-underline">
				<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-8 w-8 text-primary">
					<path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"></path><path d="m14.5 4-5 16"></path>
				</svg>
				<span class="font-bold text-xl text-dark-text tracking-tight">{SITE_TITLE}</span>
			</a>
			<div class="hidden md:flex items-center space-x-8">
				<a href="/#about" class="text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline">About</a>
				<a href="/blog" class="text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline">Blog</a>
				<a href="/#speak" class="text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline">Speak</a>
				<a href="/#contact" class="text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline">Contact</a>
			</div>
			<div class="md:hidden flex items-center">
				<button id="mobile-menu-btn" class="text-dark-text hover:text-primary focus:outline-none" aria-label="Toggle menu">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
						<path d="M4 5h16"></path><path d="M4 12h16"></path><path d="M4 19h16"></path>
					</svg>
				</button>
			</div>
		</div>
		<div id="mobile-menu" class="hidden md:hidden mt-4 pb-2 space-y-2">
			<a href="/#about" class="block text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline py-2">About</a>
			<a href="/blog" class="block text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline py-2">Blog</a>
			<a href="/#speak" class="block text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline py-2">Speak</a>
			<a href="/#contact" class="block text-sm font-medium text-dark-text hover:text-primary transition-colors no-underline py-2">Contact</a>
		</div>
	</div>
</nav>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => {
		menu?.classList.toggle('hidden');
	});
</script>
